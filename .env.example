SERVICE_NOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICE_NOW_USERNAME=your-service-account-username
SERVICE_NOW_PASSWORD=your-service-account-password

# Senior/user profile table.
# Real table name may differ from this default - confirm with
# Senior_stuff/scripts/list_servicenow_fields.py before assuming it exists.
SERVICE_NOW_TABLE=u_senior_profiles
# The column that links a profile row to its u_user login record. On the real
# instance this is the u_user reference (verified via dump_servicenow.py) —
# 'sys_id' would make the app look up profiles by the LOGIN record's sys_id,
# which never matches and 404s every caregiver/verification lookup.
SERVICE_NOW_FIELD_USER_ID=u_user
SERVICE_NOW_FIELD_EMAIL=u_email
SERVICE_NOW_FIELD_NAME=u_full_name
SERVICE_NOW_FIELD_PHONE=u_phone
SERVICE_NOW_FIELD_GENDER=u_gender
SERVICE_NOW_FIELD_DATE_OF_BIRTH=u_date_of_birth
SERVICE_NOW_FIELD_BLOOD_TYPE=u_blood_type
SERVICE_NOW_FIELD_ALLERGIES=u_allergies
SERVICE_NOW_FIELD_MEDICAL_CONDITIONS=u_medical_conditions
SERVICE_NOW_FIELD_POINTS=u_points
SERVICE_NOW_FIELD_LAST_CHECK_IN_AT=u_last_check_in_at
SERVICE_NOW_FIELD_GAME_REWARD_DATE=u_game_reward_date
SERVICE_NOW_FIELD_LOCATION_ZONES=u_location_zones
SERVICE_NOW_FIELD_ADDRESS=u_address
SERVICE_NOW_FIELD_EMERGENCY_CONTACT_NAME=u_emergency_contact_name
SERVICE_NOW_FIELD_EMERGENCY_CONTACT_PHONE=u_emergency_contact_phone
SERVICE_NOW_FIELD_REWARD_HISTORY=u_reward_history

# Daily check-in time windows.
CHECK_IN_TIME_ZONE=Asia/Singapore
CHECK_IN_MORNING_START=05:00
CHECK_IN_MORNING_END=09:00
CHECK_IN_EVENING_START=17:00
CHECK_IN_EVENING_END=23:59

# Login table used by the app login screen.
SERVICE_NOW_LOGIN_TABLE=u_user
SERVICE_NOW_LOGIN_FIELD_USERNAME=u_username
SERVICE_NOW_LOGIN_FIELD_EMAIL=u_email
SERVICE_NOW_LOGIN_FIELD_PASSWORD=u_password
SERVICE_NOW_LOGIN_FIELD_NAME=u_full_name
SERVICE_NOW_LOGIN_FIELD_ROLE=u_role
SERVICE_NOW_LOGIN_FIELD_ACTIVE=u_active
SERVICE_NOW_LOGIN_FIELD_LAST_LOGIN=u_last_login
SERVICE_NOW_LOGIN_FIELD_LAST_CHECK_IN=u_last_check_in

# SOS alert table.
SERVICE_NOW_SOS_ALERT_TABLE=u_sos_alert
SERVICE_NOW_SOS_ALERT_FIELD_LOCATION=u_location
SERVICE_NOW_SOS_ALERT_FIELD_MESSAGE=u_message
SERVICE_NOW_SOS_ALERT_FIELD_SENIOR_NAME=u_senior_name
SERVICE_NOW_SOS_ALERT_FIELD_SENIOR_PHONE=u_senior_phone
SERVICE_NOW_SOS_ALERT_FIELD_STATUS=u_status

# Caregiver profile table. This links a caregiver user to a senior profile.
SERVICE_NOW_CAREGIVER_CONNECTION_TABLE=u_caregiver_profiles
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_USER=u_user
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_SENIOR=u_senior
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_RELATIONSHIP=u_relationship
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_EMERGENCY_CONTACT_NAME=u_emergency_contact_name
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_EMERGENCY_CONTACT_PHONE=u_emergency_contact_phone
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_IS_NOK=u_is_nok

# Medicine table.
SERVICE_NOW_MEDICINE_TABLE=u_medicine
SERVICE_NOW_MEDICINE_FIELD_SENIOR=u_senior
SERVICE_NOW_MEDICINE_FIELD_DOSE=u_dosage
SERVICE_NOW_MEDICINE_FIELD_TIME=u_time
SERVICE_NOW_MEDICINE_FIELD_FREQUENCY=u_frequency
SERVICE_NOW_MEDICINE_FIELD_STATUS=u_status
SERVICE_NOW_MEDICINE_FIELD_NOTES=u_notes
SERVICE_NOW_MEDICINE_FIELD_CURRENT_MEDICATION=u_current_medication
SERVICE_NOW_MEDICINE_FIELD_IS_EXTRA=u_is_extra

# Family verification table. This stores the 6-digit code before linking a family member.
SERVICE_NOW_FAMILY_VERIFICATION_TABLE=u_verification_code
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_SENIOR=u_senior_id
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_FAMILY_EMAIL=u_family_email
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_CODE=u_code
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_EXPIRES_AT=u_expires_at
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_VERIFIED_AT=u_verified_at
SERVICE_NOW_FAMILY_VERIFICATION_FIELD_FAMILY_USER=u_family_user_id

SENIOR_DISPLAY_ID_LENGTH=8

# Sensor activity table, populated by the Senior_stuff Raspberry Pi system
# (route_engine.queue_activity_log, batched every ~60s). v1 is a single-senior
# link: SERVICE_NOW_SENSOR_SENIOR_ID must match SENIOR_ID in Senior_stuff's own
# .env. Leave SERVICE_NOW_SENSOR_SENIOR_ID blank to hide the Live Sensors panel.
SERVICE_NOW_SENSOR_ACTIVITY_TABLE=u_sensor_activity_log
SERVICE_NOW_SENSOR_SENIOR_ID=
# Senior whose home carries the Pi sensors - their card location is
# driven by live room occupancy (must match Senior_stuff SENIOR_NAME).
SERVICE_NOW_SENSOR_SENIOR_NAME=
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_SENIOR_ID=u_senior_id
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_TYPE=u_sensor_type
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_LOCATION=u_location
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_VALUE=u_value
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_STATUS=u_status
SERVICE_NOW_SENSOR_ACTIVITY_FIELD_LOGGED_AT=u_logged_at

# Optional: local API server settings.
API_PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Live clinical vitals: the mobile/web app opens a plain WebSocket to the
# controller host's MQTT bridge for the 1Hz HR/BR "Live" tab. Defaults to
# ws://<current-host>:8050/ws/live (the single consolidated dashboard process
# from Senior_stuff/start_controller.ps1). Set explicitly when the app is NOT
# served from that same host (e.g. the Android WebView build or `npm run dev`
# on a laptop):
# VITE_LIVE_WS_URL=ws://<controller-host>:8050/ws/live

# Care Assistant chatbot (caregiver/family accounts). The API key stays on
# the Node API server only - it is never sent to the browser. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
