SERVICE_NOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICE_NOW_TABLE=u_senior_connect_user
SERVICE_NOW_USERNAME=your-service-account-username
SERVICE_NOW_PASSWORD=your-service-account-password

# Optional: change these if your ServiceNow table uses different field names.
SERVICE_NOW_FIELD_USER_ID=sys_id
SERVICE_NOW_FIELD_EMAIL=u_email
SERVICE_NOW_FIELD_NAME=u_name
SERVICE_NOW_FIELD_POINTS=u_points
SERVICE_NOW_FIELD_LAST_CHECK_IN_AT=u_last_check_in_at
SERVICE_NOW_FIELD_GAME_REWARD_DATE=u_game_reward_date
CHECK_IN_TIME_ZONE=Asia/Singapore

# Login table used by the app login screen.
SERVICE_NOW_LOGIN_TABLE=u_login
SERVICE_NOW_LOGIN_FIELD_USERNAME=u_username
SERVICE_NOW_LOGIN_FIELD_EMAIL=u_email
SERVICE_NOW_LOGIN_FIELD_PASSWORD=u_password
SERVICE_NOW_LOGIN_FIELD_NAME=u_name
SERVICE_NOW_LOGIN_FIELD_ROLE=u_role
SERVICE_NOW_LOGIN_FIELD_ACTIVE=u_active

# Caregiver dashboard table used by Care Portal senior search.
SERVICE_NOW_CAREGIVER_CONNECTION_TABLE=u_caregivers_dash
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_CAREGIVER_USERNAME=u_username
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_CAREGIVER_NAME=u_caregivers_name
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_CAREGIVER_EMAIL=u_caregivers_email
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_CAREGIVER_PASSWORD=u_password
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_SENIOR_NAME=u_senior_name
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_SENIOR_PHONE=u_senior_phone
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_SENIOR_EMAIL=u_senior_email
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_RELATIONSHIP=u_relationship
SERVICE_NOW_CAREGIVER_CONNECTION_FIELD_STATUS=u_status

# Optional: local API server settings.
API_PORT=3001
CLIENT_ORIGIN=http://localhost:5173
